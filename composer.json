{
    "name": "prikotov/coding-standard",
    "description": "PHP CodeSniffer coding standard with custom sniffs",
    "type": "phpcodesniffer-standard",
    "license": "MIT",
    "keywords": ["phpcs", "coding-standard", "sniffs"],
    "authors": [
        {
            "name": "Dmitry Prikotov",
            "email": "prikotov@gmail.com"
        }
    ],
    "bin": ["bin/coding-standard-init"],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "squizlabs/php_codesniffer": "^4.0",
        "slevomat/coding-standard": "^8.0"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
        "deptrac/deptrac": "^2.0",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "PrikotovCodingStandard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PrikotovCodingStandard\\Tests\\": "tests/"
        }
    },
    "suggest": {
        "deptrac/deptrac": "For using ServiceContractDependencyRule — custom Deptrac rule that enforces service contract boundaries"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "sniff-test": "php bin/run-sniff-tests.php",
        "validate-docs": "php bin/validate-docs.php",
        "check": [
            "@test",
            "@sniff-test",
            "@validate-docs",
            "phpcs src/"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    },
    "archive": {
        "include": ["/bin/"]
    }
}
